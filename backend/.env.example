APP_NAME="ULTRA-Z Backend"
API_V1_PREFIX="/api/v1"
DATABASE_URL="sqlite:///./ultra_z.db"
ADMIN_PIN="1234"
TOKEN_SECRET_KEY="change-this-secret"
TOKEN_MAX_AGE_SECONDS="604800"

# Ollama LLM Configuration
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_CHAT_MODEL="qwen2.5:3b"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text:latest"
OLLAMA_VISION_MODEL="llava:7b"
OLLAMA_TIMEOUT="300"
OLLAMA_RETRY_ATTEMPTS="3"
OLLAMA_RETRY_DELAY="1.0"
OLLAMA_NUM_GPU="0"

# Speech-to-text
WHISPER_MODEL="base"
WHISPER_DEVICE="cpu"
WHISPER_COMPUTE_TYPE="int8"
WHISPER_LANGUAGE=""

# Text-to-speech
TTS_CACHE_DIR="storage/tts_cache"
TTS_CACHE_TTL_HOURS="24"
TTS_CACHE_MAX_FILES="500"
TTS_DEFAULT_VOICE="auto"
TTS_USE_CUDA="False"
TTS_LENGTH_SCALE="1.0"
TTS_NOISE_SCALE="0.667"
TTS_NOISE_W_SCALE="0.8"
TTS_ENGLISH_MODEL_PATH="storage/models/en_US-lessac-low.onnx"
TTS_ENGLISH_CONFIG_PATH="storage/models/en_US-lessac-low.onnx.json"

# Wakeword
WAKEWORD_ENABLED="False"
WAKEWORD_MODEL="arise"
WAKEWORD_CUSTOM_MODEL_PATH=""
WAKEWORD_THRESHOLD="0.5"
WAKEWORD_SAMPLE_RATE="16000"
WAKEWORD_CHUNK_SIZE="1280"
WAKEWORD_SILENCE_RMS_THRESHOLD="300.0"
WAKEWORD_SILENCE_TIMEOUT_SECS="1.5"
WAKEWORD_MAX_RECORD_SECS="30.0"


FFMPEG_PATH="C:\Users\PRATHAM\ffmpeg-8.1.1-essentials_build\bin\ffmpeg.exe"